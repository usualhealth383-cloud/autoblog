# ===== 본문/이미지 생성 (3단계~) =====
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ===== 트렌드: 네이버 데이터랩(선택, 한국 검색 트렌드 정확도↑) =====
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ===== 이미지: 저작권프리 스톡(선택) =====
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ===== 발행: 구글 Blogger =====
# Google Cloud Console에서 OAuth 클라이언트(데스크톱) 만든 뒤 client_secret.json 경로 지정
BLOGGER_CLIENT_SECRET_FILE=config/client_secret.json
BLOGGER_BLOG_ID=

# ===== 발행: 워드프레스 =====
# 워드프레스 관리자 > 사용자 > 응용프로그램 비밀번호(Application Password) 발급
WORDPRESS_URL=https://example.com
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# ===== 수익화: 제휴마케팅(선택) =====
# 쿠팡 파트너스(partners.coupang.com) 가입 후 발급. 구매의도 글에 추천상품 딥링크 자동삽입.
# 둘 다 있어야 쿠팡 링크가 켜짐(없으면 조용히 애드센스만).
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
# 증권사 계좌개설 제휴 링크(선택) — 금융 카테고리 글 하단에 고정 삽입.
SECURITIES_AFFILIATE_URL=
SECURITIES_AFFILIATE_TEXT=📈 주식 투자가 처음이라면? 증권 계좌 개설하고 시작하기

# ===== 일반 설정 =====
TARGET_GEO=KR
PUBLISH_HOUR=6
TRANSLATE_TO_ENGLISH=true
