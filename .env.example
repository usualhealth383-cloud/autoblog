# ===== 본문/이미지 생성 (3단계~) =====
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ===== 트렌드: 네이버 데이터랩(선택, 한국 검색 트렌드 정확도↑) =====
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ===== 이미지: 저작권프리 스톡(선택) =====
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ===== 발행: 구글 Blogger =====
# Google Cloud Console에서 OAuth 클라이언트(데스크톱) 만든 뒤 client_secret.json 경로 지정
BLOGGER_CLIENT_SECRET_FILE=config/client_secret.json
BLOGGER_BLOG_ID=

# ===== 발행: 워드프레스 =====
# 워드프레스 관리자 > 사용자 > 응용프로그램 비밀번호(Application Password) 발급
WORDPRESS_URL=https://example.com
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# ===== 일반 설정 =====
TARGET_GEO=KR
PUBLISH_HOUR=6
TRANSLATE_TO_ENGLISH=true
